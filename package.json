{
  "name": "ngovanxuanduc-site",
  "version": "1.0.0",
  "private": true,
  "description": "Personal site — static multi-page, buildable & deployable",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js && npx --yes serve dist -l 3000",
